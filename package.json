{
  "name": "crypto-tracker",
  "private": true,
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "dev": "concurrently -n api,app -c blue,green \"pnpm dev:api\" \"pnpm dev:app\"",
    "dev:api": "pnpm --filter @crypto-tracker/api dev",
    "dev:app": "pnpm --filter @crypto-tracker/mobile dev",
    "db:up": "docker compose up -d postgres",
    "db:down": "docker compose down",
    "db:migrate": "pnpm --filter @crypto-tracker/api db:migrate",
    "db:seed": "pnpm --filter @crypto-tracker/api db:seed",
    "db:studio": "pnpm --filter @crypto-tracker/api db:studio",
    "build": "pnpm -r build",
    "test": "pnpm -r test",
    "lint": "eslint .",
    "format": "prettier --write \"**/*.{ts,vue,css,md,json}\"",
    "typecheck": "pnpm -r typecheck"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "concurrently": "^9.1.2",
    "eslint": "^10.4.1",
    "eslint-plugin-vue": "^10.9.2",
    "prettier": "^3.8.4",
    "typescript-eslint": "^8.61.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "@prisma/client",
      "@prisma/engines",
      "prisma",
      "esbuild",
      "vue-demi"
    ]
  }
}
