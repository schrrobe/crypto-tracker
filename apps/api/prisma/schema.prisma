generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum SourceType {
  EXCHANGE
  WALLET
  CSV_IMPORT
  MANUAL
}

enum ProviderId {
  COINBASE
  KRAKEN
  BITVAVO
  BITPANDA
  BITCOIN
  SOLANA
  GENERIC_CSV
  MANUAL
}

enum SyncStatus {
  RUNNING
  SUCCESS
  ERROR
}

enum ImportStatus {
  PENDING_MAPPING
  COMPLETED
  FAILED
}

enum ImportKind {
  BALANCES
  TRANSACTIONS
}

enum TxType {
  BUY
  SELL
  DEPOSIT
  WITHDRAWAL
  TRANSFER
  // Staking-/Lending-Belohnung: DE = Zufluss-Einkommen (§22 Nr. 3 EStG),
  // AT = kein Zufluss-Einkommen, Anschaffungskosten 0 (§27b Abs. 2 EStG)
  STAKING_REWARD
  OTHER
}

model User {
  id            String            @id @default(uuid())
  email         String            @unique
  passwordHash  String
  baseCurrency  String            @default("EUR")
  createdAt     DateTime          @default(now())
  sources       PortfolioSource[]
  refreshTokens RefreshToken[]
}

model RefreshToken {
  id        String   @id @default(uuid())
  userId    String
  tokenHash String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

// Zentrale Abstraktion: jede Verbindung, jeder Import und jeder manuelle Topf
// ist eine PortfolioSource. Holdings hängen immer an genau einer Quelle.
model PortfolioSource {
  id           String              @id @default(uuid())
  userId       String
  type         SourceType
  provider     ProviderId
  label        String
  lastSyncAt   DateTime?
  createdAt    DateTime            @default(now())
  user         User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  credential   ExchangeCredential?
  wallet       WalletAddress?
  holdings     Holding[]
  syncRuns     SyncRun[]
  imports      CsvImport[]
  transactions Transaction[]

  @@index([userId])
}

model ExchangeCredential {
  id                  String          @id @default(uuid())
  sourceId            String          @unique
  encryptedApiKey     String
  // nullable: Bitpanda braucht nur einen API-Key, kein Secret
  encryptedApiSecret  String?
  encryptedPassphrase String?
  keyPreview          String
  source              PortfolioSource @relation(fields: [sourceId], references: [id], onDelete: Cascade)
}

model WalletAddress {
  id       String          @id @default(uuid())
  sourceId String          @unique
  chain    String
  address  String
  // Dust-/Spam-Filter: unbekannte Tokens (z.B. Solana-Mints ohne Mapping)
  // werden beim Sync standardmäßig übersprungen
  includeUnknownTokens Boolean @default(false)
  source   PortfolioSource @relation(fields: [sourceId], references: [id], onDelete: Cascade)
}

model Asset {
  id          String       @id @default(uuid())
  // Symbol ist bewusst NICHT unique — Ticker-Kollisionen existieren.
  symbol      String
  name        String
  // null = unmapped: kein Preis abrufbar, UI zeigt Hinweis
  coingeckoId String?      @unique
  iconUrl     String?
  holdings    Holding[]
  prices      AssetPrice[]
  transactions     Transaction[]
  historicalPrices HistoricalAssetPrice[]

  @@index([symbol])
}

model Holding {
  id        String          @id @default(uuid())
  sourceId  String
  assetId   String
  quantity  Decimal         @db.Decimal(38, 18)
  updatedAt DateTime        @updatedAt
  source    PortfolioSource @relation(fields: [sourceId], references: [id], onDelete: Cascade)
  asset     Asset           @relation(fields: [assetId], references: [id])

  @@unique([sourceId, assetId])
}

model Transaction {
  id           String          @id @default(uuid())
  sourceId     String
  importId     String?
  assetId      String
  type         TxType
  quantity     Decimal         @db.Decimal(38, 18)
  pricePerUnit Decimal?        @db.Decimal(38, 18)
  feeAmount    Decimal?        @db.Decimal(38, 18)
  currency     String?
  timestamp    DateTime
  // Dedupe-Anker für Chain-Importe (z.B. sol-reward:<stakeAccount>:<epoch>,
  // eth-wd:<withdrawalIndex>) — macht Reward-Syncs idempotent (skipDuplicates)
  externalRef  String?         @unique
  source       PortfolioSource @relation(fields: [sourceId], references: [id], onDelete: Cascade)
  asset        Asset           @relation(fields: [assetId], references: [id])
  transferOut  TransferLink?   @relation("TransferWithdrawal")
  transferIn   TransferLink?   @relation("TransferDeposit")

  @@index([sourceId, timestamp])
}

// Verknüpft eine WITHDRAWAL- mit einer DEPOSIT-Transaktion zu einem Transfer
// zwischen zwei Quellen: die Kostenbasis zieht im Steuerreport (DE, wallet-
// bezogenes FIFO) mit um. Beide FKs unique → maximal ein Link pro Transaktion;
// Cascade räumt den Link auf, wenn eine Seite (oder ihre Quelle) gelöscht wird.
model TransferLink {
  id             String      @id @default(uuid())
  withdrawalTxId String      @unique
  depositTxId    String      @unique
  createdAt      DateTime    @default(now())
  withdrawalTx   Transaction @relation("TransferWithdrawal", fields: [withdrawalTxId], references: [id], onDelete: Cascade)
  depositTx      Transaction @relation("TransferDeposit", fields: [depositTxId], references: [id], onDelete: Cascade)
}

model CsvImport {
  id            String          @id @default(uuid())
  sourceId      String
  filename      String
  kind          ImportKind
  status        ImportStatus    @default(PENDING_MAPPING)
  columnMapping Json?
  rawPreview    Json
  rawRows       Json?
  totalRows     Int             @default(0)
  importedRows  Int             @default(0)
  errorRows     Json?
  createdAt     DateTime        @default(now())
  source        PortfolioSource @relation(fields: [sourceId], references: [id], onDelete: Cascade)

  @@index([sourceId])
}

model SyncRun {
  id           String          @id @default(uuid())
  sourceId     String
  status       SyncStatus
  startedAt    DateTime        @default(now())
  finishedAt   DateTime?
  errorCode    String?
  errorMessage String?
  source       PortfolioSource @relation(fields: [sourceId], references: [id], onDelete: Cascade)

  @@index([sourceId, startedAt])
}

// Tagespreise (00:00 UTC) für die Steuer-Kostenbasis — Cache für CoinGecko /history.
// priceEur = null heißt: Lookup wurde versucht, CoinGecko hat keinen Preis
// (z.B. älter als 365 Tage im Free Tier) — Negativ-Cache gegen Rate-Limit-Verschwendung.
model HistoricalAssetPrice {
  id       String   @id @default(uuid())
  assetId  String
  date     DateTime @db.Date
  priceEur Decimal? @db.Decimal(24, 8)
  asset    Asset    @relation(fields: [assetId], references: [id], onDelete: Cascade)

  @@unique([assetId, date])
}

// Append-only: jüngste Zeile je Asset = aktueller Preis, ältere = Historie
model AssetPrice {
  id        String   @id @default(uuid())
  assetId   String
  priceEur  Decimal  @db.Decimal(24, 8)
  priceUsd  Decimal  @db.Decimal(24, 8)
  fetchedAt DateTime @default(now())
  asset     Asset    @relation(fields: [assetId], references: [id], onDelete: Cascade)

  @@index([assetId, fetchedAt])
}
