generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum SourceType {
  EXCHANGE
  WALLET
  CSV_IMPORT
  MANUAL
}

enum ProviderId {
  COINBASE
  KRAKEN
  BITVAVO
  BITPANDA
  BINANCE
  OKX
  BYBIT
  KUCOIN
  BITSTAMP
  GATEIO
  CRYPTOCOM
  BITCOIN
  SOLANA
  ETHEREUM
  POLYGON
  ARBITRUM
  BASE
  BSC
  LITECOIN
  DOGECOIN
  CARDANO
  XRP
  TRON
  COSMOS
  GENERIC_CSV
  MANUAL
}

enum SyncStatus {
  RUNNING
  SUCCESS
  ERROR
}

enum ImportStatus {
  PENDING_MAPPING
  COMPLETED
  FAILED
}

enum ImportKind {
  BALANCES
  TRANSACTIONS
}

enum TxType {
  BUY
  SELL
  DEPOSIT
  WITHDRAWAL
  TRANSFER
  // Staking-/Lending-Belohnung: DE = Zufluss-Einkommen (§22 Nr. 3 EStG),
  // AT = kein Zufluss-Einkommen, Anschaffungskosten 0 (§27b Abs. 2 EStG)
  STAKING_REWARD
  OTHER
}

enum Plan {
  FREE
  PRO
}

// Konto-Typ eines Bestands innerhalb einer Börse: Spot, Earn/Savings, Margin
// (Bestand kann negativ sein = Verbindlichkeit) und Futures-Wallet (Collateral).
enum HoldingAccountType {
  SPOT
  EARN
  MARGIN
  FUTURES
}

enum PositionSide {
  LONG
  SHORT
}

model User {
  id            String            @id @default(uuid())
  email         String            @unique
  passwordHash  String
  baseCurrency  String            @default("EUR")
  plan          Plan              @default(FREE)
  isAdmin       Boolean           @default(false)
  suspendedAt   DateTime?
  autoSyncEnabled Boolean         @default(true)
  stripeCustomerId     String?    @unique
  stripeSubscriptionId String?
  planUntil            DateTime?
  createdAt     DateTime          @default(now())
  // Referral program: own shareable code + who invited this user (self-relation).
  referralCode  String?           @unique
  referredById  String?
  referredBy    User?             @relation("Referrals", fields: [referredById], references: [id], onDelete: SetNull)
  referrals     User[]            @relation("Referrals")
  // Payout bank details: IBAN encrypted at rest (like ExchangeCredential), BIC/holder plaintext.
  encryptedIban String?
  ibanPreview   String?
  bankBic       String?
  bankHolder    String?
  sources       PortfolioSource[]
  portfolios    Portfolio[]
  refreshTokens RefreshToken[]
  passwordResetTokens PasswordResetToken[]
  commissionsEarned ReferralCommission[] @relation("Earned")
  payouts       Payout[]
  auditLogs     AuditLog[]        @relation("ActorAudits")
  surveyResponses SurveyResponse[]
}

// Append-only audit trail of admin actions. targetId is a plain string (no FK)
// so entries survive deletion of the target user/commission.
model AuditLog {
  id         String   @id @default(uuid())
  actorId    String?
  actorEmail String
  action     String
  targetType String
  targetId   String?
  metadata   Json?
  createdAt  DateTime @default(now())
  actor      User?    @relation("ActorAudits", fields: [actorId], references: [id], onDelete: SetNull)

  @@index([createdAt])
  @@index([targetId])
}

// Earnings ledger: 20% of each Pro invoice paid by an invited user.
// payoutId == null → still owed; set → bundled into a Payout (paid out).
model ReferralCommission {
  id              String   @id @default(uuid())
  referrerId      String
  referredUserId  String
  stripeInvoiceId String   @unique
  amountCents     Int
  currency        String
  payoutId        String?
  voidedAt        DateTime?
  createdAt       DateTime @default(now())
  referrer        User     @relation("Earned", fields: [referrerId], references: [id], onDelete: Cascade)
  payout          Payout?  @relation(fields: [payoutId], references: [id], onDelete: SetNull)

  @@index([referrerId])
  @@index([payoutId])
}

// One manual bank-transfer payout bundling a referrer's owed commissions.
model Payout {
  id          String               @id @default(uuid())
  referrerId  String
  amountCents Int
  currency    String
  createdAt   DateTime             @default(now())
  referrer    User                 @relation(fields: [referrerId], references: [id], onDelete: Cascade)
  commissions ReferralCommission[]

  @@index([referrerId])
}

model RefreshToken {
  id        String   @id @default(uuid())
  userId    String
  tokenHash String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

// Passwort-Reset: nur der Hash des opaken Tokens liegt in der DB (wie RefreshToken).
// Kurze TTL, Einmal-Nutzung (usedAt gesetzt → verbraucht).
model PasswordResetToken {
  id        String    @id @default(uuid())
  userId    String
  tokenHash String    @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

// Zentrale Abstraktion: jede Verbindung, jeder Import und jeder manuelle Topf
// ist eine PortfolioSource. Holdings hängen immer an genau einer Quelle.
// Steuersubjekt-Container: jede Quelle gehört zu genau einem Portfolio (eigenes,
// Eltern, …). Dashboard, Bestände, Transaktionen und Steuerreport sind je
// Portfolio strikt getrennt. Max. ein Default pro User (partieller Unique-Index
// in der Migration — Prisma kann WHERE-Indizes nicht abbilden).
model Portfolio {
  id        String            @id @default(uuid())
  userId    String
  label     String
  isDefault Boolean           @default(false)
  createdAt DateTime          @default(now())
  user      User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  sources   PortfolioSource[]

  @@index([userId])
}

model PortfolioSource {
  id           String              @id @default(uuid())
  userId       String
  // Restrict: Portfolio kann nur gelöscht werden, wenn es keine Quellen mehr hat
  portfolioId  String
  type         SourceType
  provider     ProviderId
  label        String
  lastSyncAt   DateTime?
  createdAt    DateTime            @default(now())
  user         User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  portfolio    Portfolio           @relation(fields: [portfolioId], references: [id], onDelete: Restrict)
  credential   ExchangeCredential?
  wallet       WalletAddress?
  holdings     Holding[]
  syncRuns     SyncRun[]
  imports      CsvImport[]
  transactions Transaction[]
  futuresPositions FuturesPosition[]

  @@index([userId])
  @@index([portfolioId])
}

model ExchangeCredential {
  id                  String          @id @default(uuid())
  sourceId            String          @unique
  encryptedApiKey     String
  // nullable: Bitpanda braucht nur einen API-Key, kein Secret
  encryptedApiSecret  String?
  encryptedPassphrase String?
  keyPreview          String
  source              PortfolioSource @relation(fields: [sourceId], references: [id], onDelete: Cascade)
}

model WalletAddress {
  id       String          @id @default(uuid())
  sourceId String          @unique
  chain    String
  address  String
  // Dust-/Spam-Filter: unbekannte Tokens (z.B. Solana-Mints ohne Mapping)
  // werden beim Sync standardmäßig übersprungen
  includeUnknownTokens Boolean @default(false)
  source   PortfolioSource @relation(fields: [sourceId], references: [id], onDelete: Cascade)
}

model Asset {
  id          String       @id @default(uuid())
  // Symbol ist bewusst NICHT unique — Ticker-Kollisionen existieren.
  symbol      String
  name        String
  // null = unmapped: kein Preis abrufbar, UI zeigt Hinweis
  coingeckoId String?      @unique
  iconUrl     String?
  holdings    Holding[]
  prices      AssetPrice[]
  transactions     Transaction[]
  historicalPrices HistoricalAssetPrice[]
  futuresPositions FuturesPosition[]

  @@index([symbol])
}

model Holding {
  id          String             @id @default(uuid())
  sourceId    String
  assetId     String
  // SPOT/EARN/MARGIN/FUTURES — ein Asset darf je Quelle unter mehreren Kontotypen liegen
  accountType HoldingAccountType @default(SPOT)
  // darf negativ sein: Margin-Verbindlichkeit (netAsset < 0)
  quantity    Decimal            @db.Decimal(38, 18)
  updatedAt   DateTime           @updatedAt
  source      PortfolioSource    @relation(fields: [sourceId], references: [id], onDelete: Cascade)
  asset       Asset              @relation(fields: [assetId], references: [id])

  @@unique([sourceId, assetId, accountType])
}

// Offene Derivat-Position (Futures/Perpetual). size in Basis-Asset-Einheiten,
// nicht Notional — Notional = size × markPrice. uPnL in quoteCurrency.
model FuturesPosition {
  id               String          @id @default(uuid())
  sourceId         String
  // gemapptes Basis-Asset, sonst null → rawSymbol als Fallback
  assetId          String?
  rawSymbol        String
  side             PositionSide
  size             Decimal         @db.Decimal(38, 18)
  entryPrice       Decimal?        @db.Decimal(38, 8)
  markPrice        Decimal?        @db.Decimal(38, 8)
  leverage         Int?
  unrealizedPnl    Decimal?        @db.Decimal(38, 8)
  quoteCurrency    String?
  liquidationPrice Decimal?        @db.Decimal(38, 8)
  updatedAt        DateTime        @updatedAt
  source           PortfolioSource @relation(fields: [sourceId], references: [id], onDelete: Cascade)
  asset            Asset?          @relation(fields: [assetId], references: [id], onDelete: SetNull)

  @@unique([sourceId, rawSymbol, side])
}

model Transaction {
  id           String          @id @default(uuid())
  sourceId     String
  importId     String?
  assetId      String
  type         TxType
  quantity     Decimal         @db.Decimal(38, 18)
  pricePerUnit Decimal?        @db.Decimal(38, 18)
  feeAmount    Decimal?        @db.Decimal(38, 18)
  currency     String?
  timestamp    DateTime
  // Dedupe-Anker für Chain-Importe (z.B. sol-reward:<stakeAccount>:<epoch>,
  // eth-wd:<withdrawalIndex>) — macht Reward-Syncs idempotent (skipDuplicates).
  // Eindeutig PRO QUELLE, nicht global: dieselbe öffentliche Adresse (Validator/
  // Stake-Account) kann von mehreren Nutzern verfolgt werden und erzeugt dann
  // identische Refs — eine globale Unique-Constraint würde den Reward des zweiten
  // Nutzers via skipDuplicates still verschlucken (Datenverlust im Steuerreport).
  externalRef  String?
  source       PortfolioSource @relation(fields: [sourceId], references: [id], onDelete: Cascade)
  asset        Asset           @relation(fields: [assetId], references: [id])
  transferOut  TransferLink?   @relation("TransferWithdrawal")
  transferIn   TransferLink?   @relation("TransferDeposit")
  swapOut      SwapLink?       @relation("SwapSell")
  swapIn       SwapLink?       @relation("SwapBuy")

  @@unique([sourceId, externalRef])
  @@index([sourceId, timestamp])
}

// Verknüpft eine WITHDRAWAL- mit einer DEPOSIT-Transaktion zu einem Transfer
// zwischen zwei Quellen: die Kostenbasis zieht im Steuerreport (DE, wallet-
// bezogenes FIFO) mit um. Beide FKs unique → maximal ein Link pro Transaktion;
// Cascade räumt den Link auf, wenn eine Seite (oder ihre Quelle) gelöscht wird.
model TransferLink {
  id             String      @id @default(uuid())
  withdrawalTxId String      @unique
  depositTxId    String      @unique
  createdAt      DateTime    @default(now())
  withdrawalTx   Transaction @relation("TransferWithdrawal", fields: [withdrawalTxId], references: [id], onDelete: Cascade)
  depositTx      Transaction @relation("TransferDeposit", fields: [depositTxId], references: [id], onDelete: Cascade)
}

// Verknüpft eine SELL (Asset A) mit einer BUY (Asset B) zu einem Krypto-zu-Krypto-
// Tausch. Steuerlich: DE = steuerpflichtig (SELL+BUY wie gehabt), AT = steuerneutral,
// Anschaffungskosten von A wandern auf B (§27b). Beide FKs unique → ein Link pro Tx.
model SwapLink {
  id        String      @id @default(uuid())
  sellTxId  String      @unique
  buyTxId   String      @unique
  createdAt DateTime    @default(now())
  sellTx    Transaction @relation("SwapSell", fields: [sellTxId], references: [id], onDelete: Cascade)
  buyTx     Transaction @relation("SwapBuy", fields: [buyTxId], references: [id], onDelete: Cascade)
}

model CsvImport {
  id            String          @id @default(uuid())
  sourceId      String
  filename      String
  kind          ImportKind
  status        ImportStatus    @default(PENDING_MAPPING)
  columnMapping Json?
  rawPreview    Json
  rawRows       Json?
  totalRows     Int             @default(0)
  importedRows  Int             @default(0)
  errorRows     Json?
  createdAt     DateTime        @default(now())
  source        PortfolioSource @relation(fields: [sourceId], references: [id], onDelete: Cascade)

  @@index([sourceId])
}

model SyncRun {
  id           String          @id @default(uuid())
  sourceId     String
  status       SyncStatus
  startedAt    DateTime        @default(now())
  finishedAt   DateTime?
  errorCode    String?
  errorMessage String?
  source       PortfolioSource @relation(fields: [sourceId], references: [id], onDelete: Cascade)

  @@index([sourceId, startedAt])
}

// Tagespreise (00:00 UTC) für die Steuer-Kostenbasis — Cache für CoinGecko /history.
// priceEur = null heißt: Lookup wurde versucht, CoinGecko hat keinen Preis
// (z.B. älter als 365 Tage im Free Tier) — Negativ-Cache gegen Rate-Limit-Verschwendung.
model HistoricalAssetPrice {
  id       String   @id @default(uuid())
  assetId  String
  date     DateTime @db.Date
  priceEur Decimal? @db.Decimal(24, 8)
  asset    Asset    @relation(fields: [assetId], references: [id], onDelete: Cascade)

  @@unique([assetId, date])
}

// Append-only: jüngste Zeile je Asset = aktueller Preis, ältere = Historie
model AssetPrice {
  id        String   @id @default(uuid())
  assetId   String
  priceEur  Decimal  @db.Decimal(24, 8)
  priceUsd  Decimal  @db.Decimal(24, 8)
  fetchedAt DateTime @default(now())
  asset     Asset    @relation(fields: [assetId], references: [id], onDelete: Cascade)

  @@index([assetId, fetchedAt])
}

enum SurveyStatus {
  DRAFT
  PUBLISHED
  CLOSED
}

enum QuestionType {
  FREE_TEXT
  SINGLE_CHOICE
  MULTI_CHOICE
}

// Admin-authored survey shown to end users. Lifecycle: DRAFT (editable) →
// PUBLISHED (visible to users, answerable) → CLOSED (read-only, results only).
model Survey {
  id          String           @id @default(uuid())
  title       String
  description String?
  status      SurveyStatus     @default(DRAFT)
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
  publishedAt DateTime?
  closedAt    DateTime?
  questions   SurveyQuestion[]
  responses   SurveyResponse[]
}

model SurveyQuestion {
  id       String         @id @default(uuid())
  surveyId String
  type     QuestionType
  prompt   String
  order    Int
  survey   Survey         @relation(fields: [surveyId], references: [id], onDelete: Cascade)
  options  SurveyOption[]
  answers  SurveyAnswer[]

  @@index([surveyId])
}

model SurveyOption {
  id         String         @id @default(uuid())
  questionId String
  label      String
  order      Int
  question   SurveyQuestion @relation(fields: [questionId], references: [id], onDelete: Cascade)

  @@index([questionId])
}

model SurveyResponse {
  id        String         @id @default(uuid())
  surveyId  String
  userId    String
  createdAt DateTime       @default(now())
  survey    Survey         @relation(fields: [surveyId], references: [id], onDelete: Cascade)
  user      User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  answers   SurveyAnswer[]

  // One response per user per survey.
  @@unique([surveyId, userId])
  @@index([surveyId])
}

model SurveyAnswer {
  id         String         @id @default(uuid())
  responseId String
  questionId String
  text       String?        // FREE_TEXT answers
  optionIds  String[]       // selected SurveyOption ids (1 for SINGLE_CHOICE, N for MULTI_CHOICE)
  response   SurveyResponse @relation(fields: [responseId], references: [id], onDelete: Cascade)
  // Restrict: questions cannot be deleted while answers exist (surveys are immutable once published).
  question   SurveyQuestion @relation(fields: [questionId], references: [id], onDelete: Restrict)

  @@index([responseId])
  @@index([questionId])
}

enum AnnouncementLevel {
  ERROR
  INFO
}

// Admin-authored broadcast banner shown to all users. Visible while active and
// within the optional [startsAt, endsAt] window.
model Announcement {
  id        String            @id @default(uuid())
  level     AnnouncementLevel
  message   String
  active    Boolean           @default(false)
  startsAt  DateTime?
  endsAt    DateTime?
  createdAt DateTime          @default(now())
  updatedAt DateTime          @updatedAt

  @@index([active])
}
