# Vorlage für die spätere prod-Umgebung.
# Secrets sollten hier aus einem Secret Manager injiziert werden (z.B. GCP Secret Manager),
# nicht aus einer Datei. Diese Vorlage dokumentiert nur die benötigten Variablen.
NODE_ENV=production
APP_ENV=prod
PORT=3000

DATABASE_URL=
JWT_SECRET=
JWT_REFRESH_SECRET=
ENCRYPTION_KEY=

# Nur exakte prod-Domains, kein localhost, kein Wildcard
CORS_ORIGINS=https://app.example.com
COINGECKO_API_KEY=
SOLANA_RPC_URL=

# Web-App-URL für Passwort-Reset-Links (muss auf die prod-Domain zeigen)
APP_PUBLIC_URL=https://app.example.com
# SMTP für Passwort-Reset-Mails — in prod erforderlich (ohne wird der Link nur geloggt)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=no-reply@app.example.com
