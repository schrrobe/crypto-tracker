# Vorlage für die spätere dev-Umgebung — Werte generieren, NICHT die local-Defaults nutzen.
NODE_ENV=production
APP_ENV=dev
PORT=3000

DATABASE_URL=postgresql://USER:PASSWORD@DEV_DB_HOST:5432/crypto_tracker?schema=public

# Generieren: openssl rand -base64 32 bzw. openssl rand -hex 32
JWT_SECRET=
JWT_REFRESH_SECRET=
ENCRYPTION_KEY=

CORS_ORIGINS=https://dev.app.example.com
# COINGECKO_API_KEY=
SOLANA_RPC_URL=https://api.mainnet-beta.solana.com

# Passwort-Reset-Links + SMTP (ohne SMTP_HOST wird der Link nur geloggt)
APP_PUBLIC_URL=https://dev.app.example.com
# SMTP_HOST=
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASSWORD=
# SMTP_FROM=no-reply@dev.app.example.com
