{
  "name": "@crypto-tracker/mobile",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vue-tsc --noEmit && vite build",
    "preview": "vite preview",
    "test": "vitest run --passWithNoTests",
    "typecheck": "vue-tsc --noEmit",
    "cap:sync": "pnpm build && cap sync",
    "cap:android": "pnpm build && cap sync android && cap run android",
    "cap:assets": "capacitor-assets generate --android"
  },
  "dependencies": {
    "@aparajita/capacitor-secure-storage": "^8.0.0",
    "@capacitor/android": "^8.4.0",
    "@capacitor/app": "^8.1.0",
    "@capacitor/browser": "^8.0.3",
    "@capacitor/core": "^8.4.0",
    "@capacitor/filesystem": "^8.1.2",
    "@capacitor/ios": "^8.4.0",
    "@capacitor/keyboard": "^8.0.3",
    "@capacitor/preferences": "^8.0.1",
    "@capacitor/share": "^8.0.1",
    "@capacitor/splash-screen": "^8.0.1",
    "@capacitor/status-bar": "^8.0.2",
    "@crypto-tracker/shared": "workspace:*",
    "@ionic/vue": "^8.4.1",
    "@ionic/vue-router": "^8.4.1",
    "ionicons": "^7.4.0",
    "jspdf": "^4.2.1",
    "jspdf-autotable": "^5.0.8",
    "pinia": "^2.3.0",
    "vue": "^3.5.13",
    "vue-i18n": "^11.4.5",
    "vue-router": "^4.5.0"
  },
  "devDependencies": {
    "@capacitor/assets": "^3.0.5",
    "@capacitor/cli": "^8.4.0",
    "@vitejs/plugin-vue": "^5.2.1",
    "@vue/test-utils": "^2.4.11",
    "happy-dom": "^20.10.2",
    "typescript": "^5.7.2",
    "vite": "^6.0.7",
    "vitest": "^2.1.8",
    "vue-tsc": "^2.2.0"
  }
}
